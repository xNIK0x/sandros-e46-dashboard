<?xml version='1.0' encoding='utf-8'?>
<widget id="com.e46.idrivelauncher" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>E46 iDrive Launcher</name>
    <description>Premium Labeled Custom 3D iDrive 7.0 Dashboard Interface for BMW E46 Coupes.</description>
    <content src="index.html" />
    <access origin="*" />
    
    <platform name="android">
        <preference name="Fullscreen" value="true" />
        <preference name="HardwareAccelerated" value="true" />
        
        <!-- Hardware Permission Strings to allow reading offline files -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
        </config-file>

        <!-- Inject System Home Launcher intents -->
        <config-file target="AndroidManifest.xml" parent="/manifest/application/activity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </config-file>
    </platform>
</widget>
