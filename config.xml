<?xml version='1.0' encoding='utf-8'?>
<widget id="com.bmw.e46hud" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>E46 Minimalist HUD</name>
    <description>Matte E46 HUD dashboard UI with local music player integration.</description>
    <author email="dev@e46hud.local" href="http://e46hud.local">Sandro</author>
    
    <content src="index.html" />
    <access origin="*" />
    
    <platform name="android">
        <allow-intent href="market:*" />
        
        <preference name="AllowUniversalAccessFromFileURLs" value="true" />
        <preference name="AllowFileAccessFromFileURLs" value="true" />
        
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
        </config-file>
    </platform>
</widget>
